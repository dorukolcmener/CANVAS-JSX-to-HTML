{
  "name": "canvas-to-html",
  "version": "1.0.0",
  "description": "Convert React canvas JSX files (Tailwind CSS + lucide-react) to a single standalone offline HTML file",
  "main": "src/index.js",
  "bin": {
    "canvas-to-html": "src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "jsx",
    "react",
    "tailwind",
    "lucide",
    "html",
    "offline",
    "converter",
    "slideshow",
    "bundle"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.488.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0"
  }
}